@startuml AgentDefinitions Demo — Notebook Walkthrough
allowmixing

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam defaultFontSize 13
skinparam ArrowColor #3B4A6B
skinparam ArrowThickness 1.5
skinparam shadowing false
skinparam NoteBorderColor #888888
skinparam NoteBackgroundColor #FFFDE7
skinparam componentStyle rectangle
skinparam PackageBorderColor #3B4A6B
skinparam PackageBackgroundColor #F8F9FF
skinparam ClassBackgroundColor #EAF2FB
skinparam ClassBorderColor #3B4A6B
skinparam ComponentBackgroundColor #DDEEFF
skinparam ComponentBorderColor #3B4A6B

title Claude Agent SDK — AgentDefinition Notebook Demos

' ─────────────────────────────────────────────
' CORE API SURFACE (from imports)
' ─────────────────────────────────────────────
package "claude_agent_sdk (imports)" #EAF2FB {

  class ClaudeAgentOptions {
    + allowed_tools : list[str]
    + agents : dict[str, AgentDefinition]
    + system_prompt : str
    + model : str
    + permission_mode : str
    + max_turns : int
    + cwd : str | Path
  }

  class AgentDefinition {
    + description : str
    + prompt : str
    + tools : list[str]
  }

  class query {
    + prompt : str
    + options : ClaudeAgentOptions
    --
    yields AssistantMessage | ResultMessage
  }

  abstract class Message {}

  class AssistantMessage {
    + content : list[Block]
    + parent_tool_use_id : str
  }

  class ResultMessage {
    + result : str
    + parent_tool_use_id : str
  }

  class ToolUseBlock {
    + name : str
    + input : dict
  }

  class TextBlock {
    + text : str
  }

  ClaudeAgentOptions "1" *--> "0..*" AgentDefinition : agents dict
  query --> ClaudeAgentOptions : uses
  query ..> Message : yields
  Message <|-- AssistantMessage
  Message <|-- ResultMessage
  AssistantMessage "1" *--> "0..*" ToolUseBlock
  AssistantMessage "1" *--> "0..*" TextBlock
}

' ─────────────────────────────────────────────
' DEMO 1: SINGLE SUBAGENT (Section 6)
' ─────────────────────────────────────────────
package "Demo 1 — Single Subagent\n(demo_single_subagent)" #E8F8E8 {
  component "Orchestrator\n(claude-sonnet-4-5)" as D1_ORC
  component "code-reviewer\n[Read, Glob, Grep]" as D1_CR

  note right of D1_CR
    description: "Expert code reviewer"
    prompt: "Senior Python engineer..."
    tools: [Read, Glob, Grep]
  end note

  D1_ORC -right-> D1_CR : Agent tool call\n(review Python fn)
  D1_CR -right-> D1_ORC : review + suggestions
}

' ─────────────────────────────────────────────
' DEMO 2: MULTIPLE SUBAGENTS (Section 7)
' ─────────────────────────────────────────────
package "Demo 2 — Multiple Subagents\n(demo_multiple_subagents)" #FFF4E0 {
  component "Orchestrator\n(system_prompt: expert orchestrator)" as D2_ORC
  component "security-auditor\n[Read, Grep]" as D2_SA
  component "performance-analyst\n[Read]" as D2_PA
  component "doc-writer\n[none]" as D2_DW

  D2_ORC -down-> D2_SA : spawn (SQL injection snippet)
  D2_ORC -down-> D2_PA : spawn (algorithm review)
  D2_ORC -down-> D2_DW : spawn (docstring gen)

  D2_SA -up-> D2_ORC : OWASP findings
  D2_PA -up-> D2_ORC : Big-O analysis
  D2_DW -up-> D2_ORC : Google-style docstrings

  note bottom of D2_ORC
    Orchestrator synthesises all
    results into a consolidated report
  end note
}

' ─────────────────────────────────────────────
' DEMO 3: FILE-AWARE SUBAGENT (Section 8)
' ─────────────────────────────────────────────
package "Demo 3 — File-Aware Subagent\n(demo_file_aware_subagent)" #F3E8FF {
  folder "tmpdir (cwd)" as D3_DIR {
    artifact "main.py"
    artifact "utils.py"
    artifact "config.py (DEBUG=True, hardcoded secret)"
  }

  component "Orchestrator\npermission_mode=acceptEdits" as D3_ORC
  component "file-scanner\n[Read, Glob, Grep]" as D3_FS

  note right of D3_FS
    Scans for: hardcoded secrets,
    DEBUG=True, API keys, passwords
  end note

  D3_ORC -right-> D3_FS : spawn
  D3_FS -down-> D3_DIR : Glob + Grep + Read
  D3_DIR -up-> D3_FS : file contents
  D3_FS -left-> D3_ORC : security findings
}

' ─────────────────────────────────────────────
' DEMO 4: SEQUENTIAL PIPELINE (Section 10)
' ─────────────────────────────────────────────
package "Demo 4 — Sequential Pipeline\n(demo_sequential_pipeline)" #FDE8E8 {
  component "researcher\n[none]" as D4_RS
  component "writer\n[none]" as D4_WR
  component "editor\n[none]" as D4_ED
  component "Final\nPolished Output" as D4_OUT

  note top of D4_RS
    Step 1: 5 bullet points
    about given topic
  end note
  note top of D4_WR
    Step 2: bullet points
    → coherent paragraph
  end note
  note top of D4_ED
    Step 3: proofread
    grammar + clarity
  end note

  D4_RS -right-> D4_WR : research_output\n(bullet points)
  D4_WR -right-> D4_ED : draft_output\n(paragraph)
  D4_ED -right-> D4_OUT : final_output\n(polished text)
}

' ─────────────────────────────────────────────
' PAGE 2: PARENT_TOOL_USE_ID TRACING
' ─────────────────────────────────────────────
@enduml